# Legacy API base URL for the full Buddybug app.
# Keep this only if you still need the existing API-backed product locally.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Pre-launch landing mode
NEXT_PUBLIC_PRELAUNCH_MODE=true
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Pre-launch Postgres and email delivery
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/buddybug
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/buddybug
RESEND_API_KEY=
EMAIL_FROM=Buddybug <stories@updates.buddybug.app>
SUPPORT_EMAIL=support@buddybug.app
CRON_SECRET=replace-with-a-long-random-secret
STORY_TOKEN_TTL_DAYS=365
