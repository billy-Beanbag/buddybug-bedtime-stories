{
  "name": "buddybug_frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Mobile-first frontend shell for Buddybug Storylight",
  "scripts": {
    "dev": "next dev --webpack --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "next": "^16.1.6",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
