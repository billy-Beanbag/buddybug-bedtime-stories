APP_NAME=Buddybug Storylight Backend
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
ENABLE_REQUEST_ID_LOGGING=true
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_PER_MINUTE=10
BILLING_RATE_LIMIT_PER_MINUTE=20
DATABASE_URL=postgresql://buddybug:buddybug@db:5432/buddybug
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PREMIUM_MONTHLY=
STRIPE_SUCCESS_URL=http://localhost:3000/profile?billing=success
STRIPE_CANCEL_URL=http://localhost:3000/profile?billing=cancel
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Optional: regex for Vercel (production + previews), e.g. ^https://.*\.vercel\.app$
# CORS_ALLOW_ORIGIN_REGEX=
STORAGE_BACKEND=local
STORAGE_LOCAL_BASE_PATH=./storage
STORAGE_PUBLIC_BASE_URL=http://localhost:8000
S3_BUCKET_NAME=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
STORY_GENERATION_API_KEY=
STORY_GENERATION_MODEL=
STORY_GENERATION_BASE_URL=https://api.openai.com/v1
STORY_GENERATION_TIMEOUT_SECONDS=45
STORY_GENERATION_CANDIDATE_COUNT=2
STORY_GENERATION_DEBUG=false
STORY_GENERATION_REQUIRE_LIVE=false
ILLUSTRATION_GENERATION_PROVIDER=mock
ILLUSTRATION_GENERATION_API_KEY=
ILLUSTRATION_GENERATION_MODEL=
ILLUSTRATION_GENERATION_BASE_URL=https://api.openai.com/v1
ILLUSTRATION_GENERATION_TIMEOUT_SECONDS=60
ILLUSTRATION_GENERATION_DEBUG=false
